<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Wedding Theme Generator — Smart Shaadi</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0f1a; --surface: #1a1a2e; --card: #16213e;
    --gold: #f0c060; --gold2: #e8a020; --green: #4ade80;
    --text: #f0ece8; --muted: #9090b0; --border: #2a2a4a;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--bg); color: var(--text); font-family: 'Poppins', sans-serif; min-height: 100vh; }

  nav {
    background: rgba(15,15,26,0.95); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between;
    position: sticky; top: 0; z-index: 100;
  }
  .logo { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--gold); text-decoration: none; }
  .logo span { color: var(--green); }
  .nav-links { display: flex; gap: 1.5rem; list-style: none; }
  .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.9rem; transition: color 0.2s; }
  .nav-links a:hover { color: var(--gold); }
  .nav-badge { background: linear-gradient(135deg, var(--gold), var(--gold2)); color: #0f0f1a; padding: 0.3rem 0.9rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }

  .hero {
    text-align: center; padding: 4rem 2rem 2rem;
    background: radial-gradient(ellipse at 50% 0%, rgba(240,192,96,0.12) 0%, transparent 60%);
  }
  .hero-icon { font-size: 3.5rem; margin-bottom: 1rem; display: block; animation: float 3s ease-in-out infinite; }
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
  .hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 4vw, 3rem); color: var(--gold); }
  .hero p { color: var(--muted); margin-top: 0.8rem; font-size: 1rem; max-width: 500px; margin-inline: auto; }
  .tag { display: inline-block; background: rgba(74,222,128,0.15); color: var(--green); border: 1px solid rgba(74,222,128,0.3); border-radius: 20px; padding: 0.3rem 1rem; font-size: 0.8rem; margin-top: 1rem; }

  .container { max-width: 860px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; margin-bottom: 1.5rem; }
  .card-title { font-family: 'Playfair Display', serif; color: var(--gold); font-size: 1.2rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; }

  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media(max-width:600px){ .form-grid { grid-template-columns: 1fr; } }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field.full { grid-column: 1/-1; }
  label { font-size: 0.82rem; color: var(--muted); font-weight: 500; }
  input, select, textarea {
    background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
    color: var(--text); padding: 0.75rem 1rem; font-family: 'Poppins', sans-serif;
    font-size: 0.9rem; outline: none; transition: border-color 0.2s; width: 100%;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(240,192,96,0.1); }
  select option { background: var(--surface); }

  /* Vibe selection */
  .vibe-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 0.8rem; }
  .vibe-card {
    background: var(--surface); border: 2px solid var(--border);
    border-radius: 12px; padding: 1rem 0.8rem; cursor: pointer;
    text-align: center; transition: all 0.25s; user-select: none;
  }
  .vibe-card .emoji { font-size: 2rem; display: block; margin-bottom: 0.4rem; }
  .vibe-card .name { font-size: 0.82rem; font-weight: 600; }
  .vibe-card .desc { font-size: 0.72rem; color: var(--muted); margin-top: 0.2rem; }
  .vibe-card:hover { border-color: var(--gold); transform: translateY(-2px); }
  .vibe-card.active { border-color: var(--gold); background: rgba(240,192,96,0.1); }
  .vibe-card.active .name { color: var(--gold); }

  .btn-generate {
    width: 100%; padding: 1rem;
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    color: #0f0f1a; border: none; border-radius: 12px;
    font-family: 'Poppins', sans-serif; font-size: 1rem; font-weight: 700;
    cursor: pointer; transition: all 0.3s; margin-top: 1rem;
  }
  .btn-generate:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(240,192,96,0.3); }
  .btn-generate:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

  .loading { text-align: center; padding: 3rem; display: none; }
  .spinner { width: 48px; height: 48px; border: 3px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading p { color: var(--muted); font-size: 0.9rem; }

  .result-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; display: none; animation: slideIn 0.4s ease; }
  @keyframes slideIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
  .result-header { background: linear-gradient(135deg, rgba(240,192,96,0.15), rgba(74,222,128,0.08)); border-bottom: 1px solid var(--border); padding: 1.2rem 1.8rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.8rem; }
  .result-title { font-family: 'Playfair Display', serif; color: var(--gold); font-size: 1.1rem; }
  .action-btns { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  .btn-action { background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; font-size: 0.8rem; font-family: 'Poppins', sans-serif; transition: all 0.2s; }
  .btn-action:hover { border-color: var(--gold); color: var(--gold); }

  /* COLOR PALETTE PREVIEW */
  .palette-preview { padding: 1.5rem 2rem; border-bottom: 1px solid var(--border); display: none; }
  .palette-preview h3 { color: var(--gold); font-size: 0.9rem; margin-bottom: 0.8rem; }
  .palette-swatches { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .swatch { width: 48px; height: 48px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.2); transition: transform 0.2s; cursor: pointer; }
  .swatch:hover { transform: scale(1.2); }

  .theme-content { padding: 2rem; white-space: pre-wrap; line-height: 1.9; font-size: 0.92rem; }

  .toast { position: fixed; bottom: 2rem; right: 2rem; background: var(--green); color: #0f0f1a; padding: 0.8rem 1.5rem; border-radius: 10px; font-weight: 600; font-size: 0.9rem; transform: translateY(100px); opacity: 0; transition: all 0.3s; z-index: 999; }
  .toast.show { transform: translateY(0); opacity: 1; }

  @media(max-width:480px){ nav { padding: 0.8rem 1rem; } .nav-links { display: none; } .card { padding: 1.3rem; } }
</style>
</head>
<body>

<nav>
  <a href="/" class="logo">Smart Shaadi <span>💍</span></a>
  <ul class="nav-links">
    <li><a href="/ai-invitation-writer.html">Invitation</a></li>
    <li><a href="/ai-planning-timeline.html">Timeline</a></li>
    <li><a href="/ai-budget-calculator.html">Budget</a></li>
  </ul>
  <span class="nav-badge">✨ AI Powered</span>
</nav>

<div class="hero">
  <span class="hero-icon">🎨</span>
  <h1>AI Wedding Theme Generator</h1>
  <p>Apni dream wedding ka perfect theme aur color palette ek click mein pao!</p>
  <span class="tag">🤖 Color Palette · Decor Ideas · Mood Board</span>
</div>

<div class="container">
  <div class="card">
    <div class="card-title">💫 Apna Vibe Chunein</div>
    <div class="vibe-grid">
      <div class="vibe-card active" data-vibe="Royal Mughal">
        <span class="emoji">👑</span>
        <div class="name">Royal Mughal</div>
        <div class="desc">Grand & Opulent</div>
      </div>
      <div class="vibe-card" data-vibe="Floral Garden">
        <span class="emoji">🌸</span>
        <div class="name">Floral Garden</div>
        <div class="desc">Fresh & Romantic</div>
      </div>
      <div class="vibe-card" data-vibe="Rajputana Heritage">
        <span class="emoji">🏰</span>
        <div class="name">Rajputana</div>
        <div class="desc">Traditional & Bold</div>
      </div>
      <div class="vibe-card" data-vibe="Modern Minimal">
        <span class="emoji">🤍</span>
        <div class="name">Modern Minimal</div>
        <div class="desc">Sleek & Elegant</div>
      </div>
      <div class="vibe-card" data-vibe="Bollywood Glam">
        <span class="emoji">✨</span>
        <div class="name">Bollywood Glam</div>
        <div class="desc">Dramatic & Sparkly</div>
      </div>
      <div class="vibe-card" data-vibe="Beach Destination">
        <span class="emoji">🌊</span>
        <div class="name">Beach Wedding</div>
        <div class="desc">Breezy & Tropical</div>
      </div>
      <div class="vibe-card" data-vibe="Rustic Bohemian">
        <span class="emoji">🌿</span>
        <div class="name">Rustic Boho</div>
        <div class="desc">Earthy & Whimsical</div>
      </div>
      <div class="vibe-card" data-vibe="Vintage Old World">
        <span class="emoji">🕯️</span>
        <div class="name">Vintage</div>
        <div class="desc">Timeless & Classic</div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">📝 More Details</div>
    <div class="form-grid">
      <div class="field">
        <label>Season / Mausam</label>
        <select id="season">
          <option value="winter">❄️ Winter (Oct-Feb)</option>
          <option value="spring">🌸 Spring (March-April)</option>
          <option value="summer">☀️ Summer (May-June)</option>
          <option value="monsoon">🌧️ Monsoon (July-Sep)</option>
        </select>
      </div>
      <div class="field">
        <label>Venue Type</label>
        <select id="venueType">
          <option value="banquet hall">Banquet Hall</option>
          <option value="outdoor garden">Outdoor Garden</option>
          <option value="rooftop">Rooftop</option>
          <option value="heritage palace">Heritage Palace/Fort</option>
          <option value="beach">Beach</option>
          <option value="farmhouse">Farmhouse</option>
          <option value="5 star hotel">5 Star Hotel</option>
        </select>
      </div>
      <div class="field">
        <label>Budget for Decor</label>
        <select id="decorBudget">
          <option value="1-3 lakh">₹1-3 Lakh</option>
          <option value="3-7 lakh" selected>₹3-7 Lakh</option>
          <option value="7-15 lakh">₹7-15 Lakh</option>
          <option value="15+ lakh">₹15 Lakh+</option>
        </select>
      </div>
      <div class="field">
        <label>Favourite Colors (Optional)</label>
        <input type="text" id="favColors" placeholder="e.g. deep red, gold, ivory" />
      </div>
      <div class="field full">
        <label>Inspiration / Koi Specific Style?</label>
        <input type="text" id="inspiration" placeholder="e.g. Deepika-Ranveer wedding, Isha Ambani style, Pinterest board colors..." />
      </div>
    </div>
  </div>

  <button class="btn-generate" onclick="generateTheme()">
    🎨 Generate My Dream Theme — AI Se Banao
  </button>

  <div class="loading" id="loading">
    <div class="spinner"></div>
    <p>AI aapka dream wedding theme design kar raha hai... 🎨</p>
  </div>

  <div class="result-card" id="resultCard">
    <div class="result-header">
      <span class="result-title">🎨 Aapka Wedding Theme</span>
      <div class="action-btns">
        <button class="btn-action" onclick="copyTheme()">📋 Copy</button>
        <button class="btn-action" onclick="shareWhatsApp()">📱 Share</button>
        <button class="btn-action" onclick="generateTheme()">🔄 New Theme</button>
      </div>
    </div>
    <div class="palette-preview" id="palettePreview">
      <h3>🎨 Color Palette Preview</h3>
      <div class="palette-swatches" id="swatches"></div>
    </div>
    <div class="theme-content" id="themeText"></div>
  </div>
</div>

<div class="toast" id="toast">✅ Copied!</div>

<script>
let selectedVibe = 'Royal Mughal';

document.querySelectorAll('.vibe-card').forEach(card => {
  card.addEventListener('click', () => {
    document.querySelectorAll('.vibe-card').forEach(c => c.classList.remove('active'));
    card.classList.add('active');
    selectedVibe = card.dataset.vibe;
  });
});

// Extract hex colors from text and display swatches
function extractAndShowColors(text) {
  const hexPattern = /#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})\b/g;
  const matches = [...text.matchAll(hexPattern)];
  const preview = document.getElementById('palettePreview');
  const swatches = document.getElementById('swatches');
  swatches.innerHTML = '';

  if (matches.length > 0) {
    const seen = new Set();
    matches.forEach(m => {
      if (!seen.has(m[0]) && seen.size < 8) {
        seen.add(m[0]);
        const s = document.createElement('div');
        s.className = 'swatch';
        s.style.background = m[0];
        s.title = m[0];
        s.onclick = () => navigator.clipboard.writeText(m[0]);
        swatches.appendChild(s);
      }
    });
    if (swatches.children.length > 0) preview.style.display = 'block';
  }
}

async function generateTheme() {
  const season = document.getElementById('season').value;
  const venueType = document.getElementById('venueType').value;
  const decorBudget = document.getElementById('decorBudget').value;
  const favColors = document.getElementById('favColors').value;
  const inspiration = document.getElementById('inspiration').value;

  const btn = document.querySelector('.btn-generate');
  btn.disabled = true;
  document.getElementById('loading').style.display = 'block';
  document.getElementById('resultCard').style.display = 'none';

  const systemPrompt = `You are a top Indian wedding decor designer and theme consultant. You create complete, stunning wedding theme concepts with color palettes, decor ideas, fabric suggestions, floral arrangements, lighting, and vendor tips. Always include specific HEX color codes for the color palette. Use Hinglish language. Be creative, specific, and practical.`;

  const userPrompt = `Create a complete wedding theme concept with these preferences:

Vibe/Theme Style: ${selectedVibe}
Season: ${season}
Venue Type: ${venueType}
Decor Budget: ${decorBudget}
Preferred Colors: ${favColors || 'Not specified, suggest best'}
Inspiration: ${inspiration || 'Classic Indian elegance'}

Please provide:

1. 🎨 THEME NAME & CONCEPT
   - Unique, memorable theme name
   - 2-3 sentence mood description

2. 🌈 COLOR PALETTE (include HEX codes)
   - Primary color + HEX
   - Secondary color + HEX
   - Accent color 1 + HEX
   - Accent color 2 + HEX
   - Neutral/Base color + HEX

3. 💐 FLORAL ARRANGEMENT IDEAS
   - Main flowers & colors
   - Centerpiece suggestions
   - Entrance decor
   - Stage backdrop

4. ✨ LIGHTING CONCEPT
   - Type of lighting
   - Specific suggestions
   - Ambiance tips

5. 🏺 KEY DECOR ELEMENTS
   - 6-8 must-have decor items
   - DIY vs professional tips

6. 👗 OUTFIT COLOR COORDINATION
   - Bridal outfit suggestions
   - Groom color coordination
   - Family color theme

7. 📸 PHOTO BACKDROP IDEAS
   - 3 unique backdrop concepts

8. 💰 BUDGET BREAKDOWN
   - How to allocate decor budget

9. 🛒 VENDOR & SHOPPING TIPS
   - Where to source items in India

Make it dreamy, detailed, and culturally rich!`;

  try {
    const res = await fetch('/api/groq-agent', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ system: systemPrompt, messages: [{role: 'user', content: userPrompt}] })
    });
    const data = await res.json();
    const text = data.choices[0].message.content;
    document.getElementById('themeText').textContent = text;
    document.getElementById('resultCard').style.display = 'block';
    extractAndShowColors(text);
    document.getElementById('resultCard').scrollIntoView({behavior: 'smooth', block: 'start'});
  } catch(e) {
    alert('Error: ' + e.message);
  } finally {
    btn.disabled = false;
    document.getElementById('loading').style.display = 'none';
  }
}

function copyTheme() {
  navigator.clipboard.writeText(document.getElementById('themeText').textContent).then(() => {
    const t = document.getElementById('toast');
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  });
}

function shareWhatsApp() {
  const text = document.getElementById('themeText').textContent;
  window.open(`https://wa.me/?text=${encodeURIComponent('Meri wedding theme idea 🎨\n\n' + text.substring(0, 800) + '\n\nSmartShaadi.online')}`, '_blank');
}
</script>
</body>
</html>

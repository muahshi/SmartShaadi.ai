<script>
/* FLOATS */
(()=>{
  const c=document.getElementById('floats');
  ['🎨','🌸','✨','💐','🕯️','👑','🌿','💜','🌈','🎊','🌺','🦋'].forEach(e=>{
    const s=document.createElement('span');
    s.className='fl';
    s.textContent=e;
    s.style.cssText=`position:absolute;left:${Math.random()*100}%;font-size:${18+Math.random()*28}px;animation-duration:${17+Math.random()*20}s;animation-delay:-${Math.random()*30}s;--r:${-20+Math.random()*40}deg`;
    c.appendChild(s);
  });
})();

/* VIBE SELECT */
let selectedVibe='Royal Mughal';
document.querySelectorAll('.vibe-card').forEach(c=>{
  c.addEventListener('click',()=>{
    document.querySelectorAll('.vibe-card').forEach(v=>v.classList.remove('on'));
    c.classList.add('on');
    selectedVibe=c.dataset.v;
    updateStrip();
  });
});
function selectVibe(v){
  const card=document.querySelector(`.vibe-card[data-v="${v}"]`);
  if(card){card.click();card.scrollIntoView({behavior:'smooth',block:'center'});}
}

/* LIVE STRIP */
function updateStrip(){
  const card=document.querySelector('.vibe-card.on');
  document.getElementById('psVibe').textContent=card?.querySelector('.vibe-emoji')?.textContent||'🎨';
  document.getElementById('psBudget').textContent=document.getElementById('budget').value.split('(')[0].trim().split(' ')[0]||'Mid';
  const v=document.getElementById('venue').value;
  document.getElementById('psVenue').textContent=v.split('/')[0].split(' ')[0]||'Hall';
}
document.getElementById('budget').addEventListener('change',updateStrip);
document.getElementById('venue').addEventListener('change',updateStrip);
updateStrip();

/* SECTION META */
const SMETA={
  'Color Palette':{ico:'🌈',col:'#a78bfa'},
  'Floral Arrangements':{ico:'💐',col:'#f472b6'},
  'Lighting':{ico:'✨',col:'#fbbf24'},
  'Decor Elements':{ico:'🏺',col:'#fb923c'},
  'Outfit Coordination':{ico:'👗',col:'#f43f5e'},
  'Photo Backdrops':{ico:'📸',col:'#60a5fa'},
  'Budget Breakdown':{ico:'💰',col:'#4ade80'},
  'Vendor Tips':{ico:'🛒',col:'#2dd4bf'},
};

/* PARSE SECTIONS */
function parse(text){
  const secs={};const keys=Object.keys(SMETA);
  const lines=text.split('\n');let cur=null;
  lines.forEach(l=>{
    const t=l.trim();if(!t)return;
    const mk=keys.find(k=>t.toLowerCase().includes(k.toLowerCase().split(' ')[0]));
    if(mk&&t.length<80&&(t.startsWith('#')||t.startsWith('**')||/^[🌈💐✨🏺👗📸💰🛒A-Z1-9]/.test(t))){
      cur=mk;if(!secs[cur])secs[cur]=[];return;
    }
    if(!cur)return;
    const m=t.match(/^[\d\.\-\*•]+\s*(.+)/)||( t.length>5&&t.length<160?[null,t]:null);
    if(m){
      let raw=m[1].replace(/\*+/g,'').trim();if(raw.length<5)return;
      let title=raw,desc='';
      const di=raw.indexOf('—');const ci=raw.indexOf(':');
      if(di>3){title=raw.slice(0,di).trim();desc=raw.slice(di+1).trim();}
      else if(ci>2&&ci<30){title=raw.slice(0,ci).trim();desc=raw.slice(ci+1).trim();}
      // tag
      let tag='';
      if(/diy|khud|ghar/i.test(raw))tag='diy';
      else if(/₹|budget|save|sasta/i.test(raw))tag='budget';
      else if(/premium|luxury|5 star/i.test(raw))tag='premium';
      else if(/trend|popular|instagram/i.test(raw))tag='trending';
      secs[cur].push({title,desc,tag});
    }
  });
  return secs;
}

/* EXTRACT COLORS */
function extractColors(text){
  const hex=/#([A-Fa-f0-9]{6})\b/g;
  const matches=[...text.matchAll(hex)];
  const seen=new Set();const colors=[];
  matches.forEach(m=>{if(!seen.has(m[0])&&seen.size<7){seen.add(m[0]);colors.push(m[0]);}});
  return colors;
}

/* EXTRACT THEME NAME */
function extractThemeName(text){
  const lines=text.split('\n');
  for(const l of lines){
    const t=l.trim();
    if(t.length>5&&t.length<60&&(t.startsWith('#')||t.startsWith('**')||/^[A-Z🎨👑🌸✨]/.test(t))){
      const clean=t.replace(/^#+\s*/,'').replace(/\*+/g,'').replace(/^(theme name|concept|title):?\s*/i,'').trim();
      if(clean.length>3)return clean;
    }
  }
  return selectedVibe+' — '+document.getElementById('venue').value.split('/')[0];
}

/* RENDER */
function renderResult(secs,text){
  // Theme name + mood
  const name=extractThemeName(text);
  document.getElementById('themeName').textContent=name;
  const moodLine=text.split('\n').slice(0,8).find(l=>/mood|concept|opulent|romantic|elegant|dramatic|timeless/i.test(l));
  document.getElementById('themeMood').textContent=(moodLine||'').replace(/^#+\s*/,'').replace(/\*+/g,'').trim().slice(0,100)||selectedVibe+' — '+document.getElementById('season').value;

  // Colors
  const colors=extractColors(text);
  const card=document.querySelector('.vibe-card.on');
  const fallbackColors=(card?.dataset?.colors||'#8B0000,#C9A84C,#4A0E2E,#F5F0E0,#1C1C1C').split(',');
  const finalColors=colors.length>=3?colors:fallbackColors;

  const paletteRow=document.getElementById('paletteRow');
  paletteRow.innerHTML='';
  const copyRow=document.getElementById('paletteCopyRow');
  copyRow.innerHTML='';
  const colorNames=['Primary','Secondary','Accent 1','Accent 2','Neutral'];
  finalColors.slice(0,5).forEach((col,i)=>{
    const wrap=document.createElement('div');
    wrap.className='swatch-wrap';
    wrap.title='Click to copy '+col;
    wrap.onclick=()=>{navigator.clipboard.writeText(col).then(()=>showToast('🎨 '+col+' copied!'));};
    wrap.innerHTML=`<div class="swatch" style="background:${col}"></div><div class="swatch-hex">${col}</div>`;
    paletteRow.appendChild(wrap);

    const btn=document.createElement('button');
    btn.className='pal-copy-btn';
    btn.textContent=(colorNames[i]||'Color '+(i+1))+' '+col;
    btn.onclick=()=>{navigator.clipboard.writeText(col).then(()=>showToast('🎨 Copied!'));};
    copyRow.appendChild(btn);
  });

  // Sections + tabs
  const tabs=document.getElementById('tabsRow');
  const wrap=document.getElementById('sectionsWrap');
  tabs.innerHTML='';wrap.innerHTML='';

  const tagCls={budget:'it-budget',diy:'it-diy',premium:'it-premium',trending:'it-trending'};
  const tagLbl={budget:'💰 Budget Tip',diy:'🔨 DIY',premium:'⭐ Premium',trending:'🔥 Trending'};

  let first=true;
  Object.entries(secs).forEach(([secName,items],idx)=>{
    if(!items||!items.length)return;
    const m=SMETA[secName]||{ico:'🎨',col:'#a78bfa'};

    const tab=document.createElement('button');
    tab.className='tab'+(first?' active':'');
    tab.textContent=m.ico+' '+secName.split(' ')[0]+' ('+items.length+')';
    const myIdx=idx;
    tab.onclick=()=>{
      document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
      document.querySelectorAll('.theme-sec').forEach(s=>s.classList.remove('show'));
      tab.classList.add('active');
      document.getElementById('ts_'+myIdx).classList.add('show');
    };
    tabs.appendChild(tab);

    const cards=items.map((item,i)=>`
      <div class="idea-card" style="--ic-color:${m.col}">
        <div class="idea-num">#${i+1}</div>
        <div class="idea-title">${item.title}</div>
        ${item.desc?`<div class="idea-desc">${item.desc}</div>`:''}
        ${item.tag?`<span class="idea-tag ${tagCls[item.tag]||'it-trending'}">${tagLbl[item.tag]||item.tag}</span>`:''}
      </div>`).join('');

    const sec=document.createElement('div');
    sec.id='ts_'+idx;
    sec.className='theme-sec'+(first?' show':'');
    sec.innerHTML=`
      <div class="tsec-card">
        <div class="tsec-head">
          <div class="tsec-title" style="color:${m.col}">${m.ico} ${secName}</div>
          <button class="tsec-copy" onclick="copySec('${secName}')">📋 Copy</button>
        </div>
        <div class="idea-grid">${cards}</div>
      </div>`;
    wrap.appendChild(sec);
    first=false;
  });
  window._secs=secs;
  window._rawText=text;
  window._colors=finalColors;
}

/* PROGRESS */
let pi;
function startProg(){
  document.getElementById('progWrap').style.display='block';
  let v=0,si=0;
  const steps=['ps1','ps2','ps3','ps4'];
  steps.forEach(s=>document.getElementById(s).className='ps');
  document.getElementById('ps1').className='ps active';
  pi=setInterval(()=>{
    v=Math.min(v+Math.random()*4.5,88);
    document.getElementById('progFill').style.width=v+'%';
    const ni=Math.floor(v/25);
    if(ni>si&&ni<4){document.getElementById(steps[si]).className='ps done';si=ni;document.getElementById(steps[si]).className='ps active';}
  },400);
}
function stopProg(){
  clearInterval(pi);
  ['ps1','ps2','ps3','ps4'].forEach(s=>document.getElementById(s).className='ps done');
  document.getElementById('progFill').style.width='100%';
  setTimeout(()=>{document.getElementById('progWrap').style.display='none';document.getElementById('progFill').style.width='0';},600);
}

/* GENERATE */
async function generate(){
  const season=document.getElementById('season').value;
  const venue=document.getElementById('venue').value;
  const budget=document.getElementById('budget').value;
  const lehnga=document.getElementById('lehengaColor').value.trim();
  const inspo=document.getElementById('inspiration').value.trim();
  const special=document.getElementById('special').value.trim();

  document.getElementById('genBtn').disabled=true;
  document.getElementById('errBox').style.display='none';
  document.getElementById('resultWrap').style.display='none';
  startProg();

  const sys=`Tu India ka top wedding decor designer aur theme consultant hai — 15+ saal experience, 300+ weddings. Tu complete wedding theme concepts banata hai — color palettes with HEX codes, decor ideas, floral arrangements, lighting concepts, outfit coordination. Hinglish mein likho. Specific, creative, practical raho. Hamesha exact HEX color codes include karo.`;

  const prompt=`Complete wedding theme concept banao:

VIBE: ${selectedVibe}
SEASON: ${season}
VENUE: ${venue}
DECOR BUDGET: ${budget}
LEHENGA COLOR: ${lehnga||'Not specified — suggest best match'}
INSPIRATION: ${inspo||'Classic Indian elegance'}
${special?'SPECIAL REQUIREMENTS: '+special:''}

EXACT SECTIONS (yeh headers use karo):
## Color Palette
Primary + Secondary + 3 Accent colors with HEX codes. Why yeh combination work karta hai.

## Floral Arrangements
Main flowers, centerpieces, entrance, stage backdrop, jaimala. Local flowers prefer karo.

## Lighting
Type of lighting, specific products/ideas, ambiance tips. Budget allocation.

## Decor Elements
8-10 must-have decor items. DIY possible vs professional needed.

## Outfit Coordination
Bride outfit color suggestions, groom coordination, family color theme.

## Photo Backdrops
3 unique backdrop concepts for Instagram-worthy shots.

## Budget Breakdown
${budget} budget ke liye allocation per element.

## Vendor Tips
Kahan se source karein India mein — online + offline.

Theme ke liye ek unique catchy name do at the top.
Hinglish mein likho. Specific, practical, Indian context. 450-550 words total.`;

  try{
    const res=await fetch('/api/groq-agent',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({system:sys,messages:[{role:'user',content:prompt}]})});
    if(!res.ok)throw new Error('Server '+res.status);
    const d=await res.json();
    // ✅ CORRECT API RESPONSE PARSING
    const text=d.choices[0].message.content;
    stopProg();

    const secs=parse(text);
    renderResult(secs,text);

    document.getElementById('resultWrap').style.display='block';
    document.getElementById('resultWrap').scrollIntoView({behavior:'smooth',block:'start'});
  }catch(e){
    stopProg();showErr('⚠️ Kuch gadbad hui. Dobara try karo. ('+e.message+')');
  }finally{document.getElementById('genBtn').disabled=false;}
}

/* COPY HELPERS */
function copySec(name){
  const items=window._secs?.[name]||[];
  const t=`🎨 ${name}\n`+items.map((s,i)=>`${i+1}. ${s.title}${s.desc?' — '+s.desc:''}`).join('\n');
  navigator.clipboard.writeText(t).then(()=>showToast('📋 '+name+' copied!'));
}
function copyAll(){
  let t=`🎨 Wedding Theme — ${selectedVibe}\nSmartShaadi.online\n\n`;
  if(window._colors?.length){t+='COLOR PALETTE:\n'+window._colors.join(' · ')+'\n\n';}
  Object.entries(window._secs||{}).forEach(([sec,items])=>{
    t+=`\n═══ ${sec.toUpperCase()} ═══\n`;
    items.forEach((s,i)=>t+=`${i+1}. ${s.title}${s.desc?' — '+s.desc:''}\n`);
  });
  t+='\n🔗 https://smartshaadi.online/ai-wedding-theme-generator.html';
  navigator.clipboard.writeText(t).then(()=>showToast('📋 Full theme copied!'));
}
function waShare(){
  const t=`🎨 Wedding Theme: ${selectedVibe}\n\nColor Palette: ${(window._colors||[]).join(', ')}\n\n${(window._rawText||'').substring(0,500)}\n\n🔗 https://smartshaadi.online/ai-wedding-theme-generator.html`;
  window.open('https://wa.me/?text='+encodeURIComponent(t));
}
function waShareTool(){window.open('https://wa.me/?text='+encodeURIComponent('Free AI Wedding Theme Generator!\n🎨 Color palette + decor ideas + outfit coordination.\nhttps://smartshaadi.online/ai-wedding-theme-generator.html'));}
function copyLink(){navigator.clipboard.writeText('https://smartshaadi.online/ai-wedding-theme-generator.html').then(()=>showToast('🔗 Link copied!'));}
function showErr(m){const b=document.getElementById('errBox');b.textContent=m;b.style.display='block';}
function showToast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2400);}
function faq(btn){
  const body=btn.nextElementSibling;const isOpen=btn.classList.contains('open');
  document.querySelectorAll('.faq-btn.open').forEach(b=>{b.classList.remove('open');b.nextElementSibling.style.maxHeight='0';});
  if(!isOpen){btn.classList.add('open');body.style.maxHeight=body.scrollHeight+'px';}
}
</script>

<script>
// Multi-select pills
function setupMultiPills(groupId) {
  document.querySelectorAll(`#${groupId} .pill`).forEach(p => {
    p.addEventListener('click', () => {
      p.classList.toggle('active');
    });
  });
}
// Single-select pills
function setupSinglePills(groupId) {
  document.querySelectorAll(`#${groupId} .pill`).forEach(p => {
    p.addEventListener('click', () => {
      document.querySelectorAll(`#${groupId} .pill`).forEach(x => x.classList.remove('active'));
      p.classList.add('active');
    });
  });
}

setupSinglePills('personalityPills');
setupSinglePills('religionPills');
setupMultiPills('colorPills');

let progressInterval;
function startProgress() {
  document.getElementById('progressWrap').style.display = 'block';
  let val = 0;
  progressInterval = setInterval(() => {
    val = Math.min(val + Math.random() * 5, 88);
    document.getElementById('progressFill').style.width = val + '%';
  }, 400);
}
function stopProgress() {
  clearInterval(progressInterval);
  document.getElementById('progressFill').style.width = '100%';
  setTimeout(() => {
    document.getElementById('progressWrap').style.display = 'none';
    document.getElementById('progressFill').style.width = '0%';
  }, 400);
}

let shareContent = '';

async function generate() {
  const city = document.getElementById('city').value.trim();
  if (!city) { showError('⚠️ City zaroori hai!'); return; }

  const season = document.getElementById('season').value;
  const budget = document.getElementById('budget').value;
  const venue = document.getElementById('venue').value;
  const personality = document.querySelector('#personalityPills .pill.active')?.dataset.val || 'Romantic & Traditional';
  const religion = document.querySelector('#religionPills .pill.active')?.dataset.val || 'Hindu';
  const colors = [...document.querySelectorAll('#colorPills .pill.active')].map(p => p.dataset.val).join(', ') || 'No preference';

  document.getElementById('genBtn').disabled = true;
  document.getElementById('errorBox').style.display = 'none';
  document.getElementById('results').style.display = 'none';
  startProgress();

  const systemPrompt = `You are India's top wedding theme designer. Create detailed, beautiful, culturally appropriate wedding themes for Indian couples. Be specific, creative, and practical. Include real vendor tips and 2026 trends.`;

  const userPrompt = `Create a complete wedding theme for:
- City: ${city}
- Season: ${season}
- Budget: ${budget}
- Venue: ${venue}
- Personality: ${personality}
- Religion/Culture: ${religion}
- Color preference: ${colors}

Return EXACTLY in this format:

THEME_NAME: [Creative theme name in Hindi/English]
TAGLINE: [One beautiful line describing the theme]
COLORS: [color1|hex1, color2|hex2, color3|hex3, color4|hex4]
OVERVIEW: [2-3 lines describing the overall vibe]

DECOR_IDEAS:
- [idea 1]
- [idea 2]
- [idea 3]
- [idea 4]
- [idea 5]

OUTFIT_SUGGESTIONS:
- Bride: [suggestion]
- Groom: [suggestion]
- Family: [suggestion]
- Guests dress code: [suggestion]

FLOWERS_AND_FRAGRANCE:
- [suggestion 1]
- [suggestion 2]
- [suggestion 3]

FOOD_THEME:
- [suggestion 1]
- [suggestion 2]

TRENDING_ELEMENTS:
- [2026 trend 1]
- [2026 trend 2]
- [2026 trend 3]

BUDGET_TIP: [One specific money-saving tip for this theme in ${city}]

Make it specific to Indian culture, ${religion} traditions, and ${city} vendors. Be creative and inspiring!`;

  try {
    const res = await fetch('/.netlify/functions/groq-agent', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        system: systemPrompt,
        messages: [{ role: 'user', content: userPrompt }]
      })
    });
    if (!res.ok) throw new Error('Server error ' + res.status);
    const data = await res.json();
    stopProgress();
    renderTheme(data.content, city, season);
  } catch (err) {
    stopProgress();
    showError('⚠️ Kuch gadbad hui. Please dobara try karein. (' + err.message + ')');
  } finally {
    document.getElementById('genBtn').disabled = false;
  }
}

function parseColors(colorStr) {
  if (!colorStr) return [];
  return colorStr.split(',').map(c => {
    const parts = c.trim().split('|');
    return { name: parts[0]?.trim() || c.trim(), hex: parts[1]?.trim() || '#888888' };
  }).filter(c => c.name);
}

function extractSection(content, key) {
  const regex = new RegExp(`${key}:([\\s\\S]*?)(?=\\n[A-Z_]+:|$)`, 'i');
  const match = content.match(regex);
  return match ? match[1].trim() : '';
}

function formatList(text) {
  if (!text) return '';
  const lines = text.split('\n').map(l => l.replace(/^[-•*]\s*/, '').trim()).filter(l => l.length > 2);
  return '<ul>' + lines.map(l => `<li>${l}</li>`).join('') + '</ul>';
}

function renderTheme(content, city, season) {
  const themeName = extractSection(content, 'THEME_NAME') || 'Your Dream Theme';
  const tagline = extractSection(content, 'TAGLINE') || '';
  const colorsRaw = extractSection(content, 'COLORS');
  const overview = extractSection(content, 'OVERVIEW') || '';
  const decor = extractSection(content, 'DECOR_IDEAS');
  const outfits = extractSection(content, 'OUTFIT_SUGGESTIONS');
  const flowers = extractSection(content, 'FLOWERS_AND_FRAGRANCE');
  const food = extractSection(content, 'FOOD_THEME');
  const trending = extractSection(content, 'TRENDING_ELEMENTS');
  const budgetTip = extractSection(content, 'BUDGET_TIP') || '';

  const colors = parseColors(colorsRaw);

  shareContent = `✨ SmartShaadi.online ne meri wedding theme suggest ki!\n\n🎨 Theme: ${themeName}\n💫 "${tagline}"\n📍 ${city} | ${season}\n\nAap bhi apni free AI wedding theme banao:\n👉 smartshaadi.online/ai-wedding-theme-generator.html`;

  const colorSwatches = colors.length > 0
    ? `<div class="color-palette">${colors.map(c => `
        <div class="color-swatch">
          <div class="swatch-circle" style="background:${c.hex}"></div>
          <div class="swatch-name">${c.name}</div>
        </div>`).join('')}</div>`
    : '';

  const sections = [
    { title: '🌸 Decor Ideas', content: formatList(decor) },
    { title: '👗 Outfit Suggestions', content: formatList(outfits) },
    { title: '💐 Flowers & Fragrance', content: formatList(flowers) },
    { title: '🍽️ Food Theme', content: formatList(food) },
    { title: '✨ 2026 Trending Elements', content: formatList(trending) },
  ].filter(s => s.content && s.content !== '<ul></ul>');

  const html = `
    <div class="theme-hero">
      <button class="copy-btn" onclick="copyTheme()">📋 Copy</button>
      <div class="theme-name">🎨 ${themeName}</div>
      <div class="theme-tagline">"${tagline}"</div>
      ${colorSwatches}
      <div style="font-size:14px;color:rgba(232,224,240,0.75);line-height:1.8">${overview}</div>
    </div>
    ${sections.map(s => `
      <div class="theme-section">
        <div class="theme-section-title">${s.title}</div>
        <div class="theme-section-body">${s.content}</div>
      </div>`).join('')}
    ${budgetTip ? `
      <div class="theme-section" style="border:1px solid rgba(255,204,51,0.2);background:rgba(255,204,51,0.05)">
        <div class="theme-section-title" style="color:var(--gold)">💰 Budget Tip for ${city}</div>
        <div class="theme-section-body">${budgetTip}</div>
      </div>` : ''}
  `;

  document.getElementById('themeResult').innerHTML = html;
  document.getElementById('shareText').textContent = shareContent;
  document.getElementById('results').style.display = 'block';
  document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function copyTheme() {
  const text = document.getElementById('themeResult').innerText;
  navigator.clipboard.writeText(text).then(() => {
    event.target.textContent = '✓ Copied!';
    setTimeout(() => event.target.textContent = '📋 Copy', 2000);
  });
}

function copyShare() {
  navigator.clipboard.writeText(shareContent).then(() => {
    event.target.textContent = '✓ Copied!';
    setTimeout(() => event.target.textContent = '📋 Share Text Copy Karo', 2000);
  });
}

function showError(msg) {
  const box = document.getElementById('errorBox');
  box.textContent = msg; box.style.display = 'block';
}
</script>

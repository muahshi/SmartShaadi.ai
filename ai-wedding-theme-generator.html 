@media(max-width:560px) { .fields-row { grid-template-columns: 1fr; } .hero { padding: 36px 16px 30px; } .card { padding: 18px 14px; } .color-palette { gap: 8px; } .swatch-circle { width: 40px; height: 40px; } }
